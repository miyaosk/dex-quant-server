MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=dex_quant
MYSQL_PASSWORD=change-me
MYSQL_DB=dex_quant

# 对外访问域名，供 Vault 安全链接等场景生成绝对地址
PUBLIC_BASE_URL=https://quant.example.com

# 管理后台登录密钥
ADMIN_API_KEY=change-me-admin-key

# 32 字节原文或 44 字符 base64；用于加密用户私钥
VAULT_MASTER_KEY=replace-with-32-byte-secret

# 服务器访问交易所时如需代理再配置
PROXY_URL=

# 有 Docker 时建议使用 docker；无 Docker 再退回 process
SANDBOX_MODE=docker
SANDBOX_IMAGE=dex-sandbox:latest
SANDBOX_TIMEOUT=120
SANDBOX_MEMORY=512m
SANDBOX_CPUS=1

DB_POOL_SIZE=5
API_PREFIX=/api/v1
DEFAULT_FEE_RATE=0.0005
DEFAULT_SLIPPAGE_BPS=2.0
MAX_BACKTEST_BARS=500000
